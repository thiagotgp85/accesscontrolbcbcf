# Exemplo de configuração necessária
# Copie para .env e preencha com seus valores

# Configuração do Sistema
SYSTEM_TITLE=ACCESS CONTROL BCB CF
PRIMARY_COLOR=#1e3a5f

# NUNCA compartilhe as credenciais reais no GitHub!
# Mantenha essas variáveis LOCALMENTE apenas
ADMIN_USERNAME=seu_usuario_aqui
ADMIN_PASSWORD=sua_senha_aqui_SEGURA

# Se usar banco de dados externo
DATABASE_URL=sua_url_do_banco_aqui
API_KEY=sua_chave_api_aqui